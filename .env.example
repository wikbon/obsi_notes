# ============================================
# Obsidian Notes Processor - Environment Config
# ============================================
# Copy this file to .env and fill in your values.
# All paths should be absolute.

# --- Obsidian Vault ---
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault
OBSIDIAN_OUTPUT_DIR=/path/to/your/obsidian/vault/processed

# --- OpenAI (required for OpenAI handler) ---
OPENAI_API_KEY=your-api-key-here

# --- LM Studio (required for LM Studio handler) ---
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL_ID=your-lmstudio-model-id

# --- Local GGUF Models (for llama-cpp-python handler) ---
# Only configure the models you plan to use.
DEEPSEEK_LLAMA_8B_PATH=/path/to/DeepSeek-R1-Distill-Llama-8B-Q8_0.gguf
DEEPSEEK_QWEN_32B_PATH=/path/to/DeepSeek-R1-Distill-Qwen-32B-Q6_K_L.gguf
DEEPSEEK_LLAMA_70B_PATH=/path/to/DeepSeek-R1-Distill-Llama-70B.gguf
